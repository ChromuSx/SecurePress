{
  "name": "com.securepress.action",
  "version": "1.1.0",
  "description": "Stream Deck plugin for Windows Hello authenticated actions",
  "author": "ChromuSx",
  "license": "MIT",
  "main": "src/plugin.ts",
  "scripts": {
    "icons": "node scripts/generate-icons.js",
    "icons:logo": "node scripts/generate-logo-assets.js",
    "build": "npm run build:auth-helper && npm run build:ts && node scripts/copy-assets.js",
    "build:ts": "tsc",
    "build:auth-helper": "dotnet publish native/SecurePress.AuthHelper/SecurePress.AuthHelper.csproj -c Release -r win-x64 --self-contained true",
    "watch": "tsc --watch",
    "test": "npm run build:ts && node --test test/*.test.js",
    "package": "node scripts/package-plugin.js",
    "package:cli": "streamdeck pack com.securepress.action.sdPlugin",
    "build:package": "npm run build && npm run package",
    "install:local": "npm run build:package && node scripts/install-local.js",
    "prebuild": "npm run icons:logo && npm run icons"
  },
  "devDependencies": {
    "@elgato/streamdeck": "^1.0.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "adm-zip": "^0.5.16",
    "sharp": "^0.34.5",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "passport-desktop": "^0.1.2",
    "ws": "^8.18.3"
  }
}
