{
  "name": "securepress-video",
  "version": "1.0.0",
  "private": true,
  "description": "Marketplace screenshots and promo video for the SecurePress Stream Deck plugin",
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render SecurePressPromo out/promo.mp4 --crf=24",
    "thumbnail": "remotion still SecurePressThumbnail out/promo-thumbnail.png",
    "hero": "remotion still SecurePressHero out/gallery-hero.png",
    "property": "remotion still SecurePressPropertyInspector out/gallery-property-inspector.png",
    "stills": "npm run thumbnail && npm run hero && npm run property"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "typescript": "^5.4.5"
  }
}
